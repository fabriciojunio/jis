# Copie para .env.local e preencha a chave para gerar currículos com a Claude.
# Sem a chave, o sistema avisa "sem token" e entrega o prompt pronto para você
# colar no Claude. No Vercel, adicione em Settings → Environment Variables.
ANTHROPIC_API_KEY=

# Modelo da Claude (opcional). Padrão: claude-opus-4-8
JIS_CV_MODEL=claude-opus-4-8
