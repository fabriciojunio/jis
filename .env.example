# ============================================================
# JIS — Job Intelligence System
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── BANCO DE DADOS (Supabase) ─────────────────────────────
# Acesse: supabase.com → Settings → Database → Connection string (JDBC)
DB_URL=jdbc:postgresql://db.XXXXXXXXXXXXXXXX.supabase.co:5432/postgres
DB_USER=postgres
DB_PASSWORD=sua_senha_supabase_aqui

# ── EMAIL (Gmail SMTP) ────────────────────────────────────
# 1. Ative autenticação de 2 fatores na sua conta Google
# 2. Acesse: myaccount.google.com/apppasswords
# 3. Crie uma "App Password" para "Mail" → copie a senha de 16 chars
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email que vai RECEBER as notificações diárias
EMAIL_ENABLED=true
EMAIL_RECIPIENT=junioad555@gmail.com
EMAIL_FROM=seuemail@gmail.com

# ── ML SERVICE ────────────────────────────────────────────
# URL do serviço de ML (Render.com free tier)
# Em desenvolvimento local: http://localhost:8000
ML_SERVICE_URL=http://localhost:8000

# ── SCHEDULER ────────────────────────────────────────────
# Cron para disparar o pipeline (padrão: 19h todos os dias)
# Formato: segundo minuto hora dia mês dia-da-semana
SCHEDULER_CRON=0 0 19 * * *

# ── TELEGRAM (opcional — configure quando tiver o token) ──
# 1. Abra @BotFather no Telegram → /newbot → copie o token
# 2. Envie uma mensagem pro bot e acesse:
#    https://api.telegram.org/bot{TOKEN}/getUpdates
# 3. Copie o chat_id da resposta
# TELEGRAM_BOT_TOKEN=1234567890:AABBCCxxxx
# TELEGRAM_CHAT_ID=123456789
